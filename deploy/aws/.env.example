# Mnemos on AWS — copy to `.env` next to docker-compose.yml and fill in.
# This host has NO Google Cloud dependency for the LLM: generation and
# embeddings both run on Amazon Bedrock. Never commit the filled-in .env
# (it is gitignored).

# --- MongoDB Atlas (cloud-agnostic; same values you already use) ---
MONGODB_URI=
MONGODB_DB=mnemos
MONGODB_VECTOR_INDEX=mnemos_vector_index
MONGODB_TEXT_INDEX=mnemos_text_index
MNEMOS_USE_MCP=0

# --- LLM generation: Amazon Bedrock (Converse) ---
# Draws down your AWS credit, no free-tier rate limits. In the Bedrock console
# (same region) enable "Model access" for BEDROCK_MODEL_ID, and create an IAM
# user with bedrock:InvokeModel + bedrock:InvokeModelWithResponseStream.
#
# Default: Amazon Nova Pro — an AWS FIRST-PARTY model, so it needs no AWS
# Marketplace subscription and works on India (AISPL) accounts with NO
# international card. The region prefix must match BEDROCK_REGION
# (apac.=Mumbai/APAC, us.=US, eu.=EU); copy the exact inference-profile id the
# Bedrock console shows for your region.
#   Cheaper/faster: apac.amazon.nova-lite-v1:0
#   Anthropic Claude works too — e.g. global.anthropic.claude-sonnet-4-5-20250929-v1:0 —
#   but Claude is a Marketplace model and its subscription needs a valid
#   international card on the AWS account (INVALID_PAYMENT_INSTRUMENT without one).
LLM_PROVIDER=bedrock
BEDROCK_MODEL_ID=apac.amazon.nova-pro-v1:0
BEDROCK_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Embeddings: Amazon Bedrock (Titan) — fully AWS, no Google key needed ---
# Uses the same AWS creds above. Titan v2 vectors are 1024-d, so the Atlas
# vector index must be built at 1024 (the runbook covers the one-time re-embed
# + index rebuild). Leave GEMINI_API_KEY empty when EMBED_PROVIDER=bedrock.
EMBED_PROVIDER=bedrock
BEDROCK_EMBED_MODEL=amazon.titan-embed-text-v2:0
BEDROCK_EMBED_DIMS=1024
GEMINI_API_KEY=

# --- Google OAuth (Gmail send + Google Calendar) ---
# Hostname is unchanged from the old deployment, so the redirect URI already
# registered on your OAuth client keeps working — only DNS moves to this box.
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REDIRECT_URI=https://mnemos-agent.aryangorde.com/auth/google/callback

# --- Public URLs ---
# Browser-facing agent URL (used to build the "connect google" OAuth link).
AGENT_PUBLIC_URL=https://mnemos-agent.aryangorde.com
# Where the agent redirects the browser after OAuth (the web origin).
MNEMOS_WEB_URL=https://mnemos.aryangorde.com
