# Mnemos on AWS — copy to `.env` next to docker-compose.yml and fill in.
# This host has NO Google Cloud dependency: the agent talks to MongoDB Atlas
# and the Gemini API directly, both over plain env vars. Never commit the
# filled-in .env (it is gitignored).

# --- MongoDB Atlas (cloud-agnostic; same values you already use) ---
MONGODB_URI=
MONGODB_DB=mnemos
MONGODB_VECTOR_INDEX=mnemos_vector_index
MONGODB_TEXT_INDEX=mnemos_text_index
MNEMOS_USE_MCP=0

# --- LLM generation: Amazon Bedrock (Converse) ---
# Draws down your AWS credit, no free-tier rate limits. In the Bedrock console
# (same region) enable "Model access" for BEDROCK_MODEL_ID, and create an IAM
# user with bedrock:InvokeModel + bedrock:InvokeModelWithResponseStream.
# The default below (Sonnet 4.5) is verified ACTIVE + working in ap-south-1.
# In-region lower-latency alternative: apac.anthropic.claude-3-7-sonnet-20250219-v1:0
# Cheaper/faster: global.anthropic.claude-haiku-4-5-20251001-v1:0
# Avoid *-sonnet-4-20250514 — AWS marks it Legacy and blocks it.
LLM_PROVIDER=bedrock
BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-5-20250929-v1:0
BEDROCK_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Embeddings: stay on Gemini/Vertex (keeps the existing Atlas index dims) ---
# Only lightweight embedding calls run here (~one per search), well under the
# free-tier limits that constrain generation. Key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
VERTEX_EMBEDDING_MODEL=text-embedding-004

# --- Google OAuth (Gmail send + Google Calendar) ---
# Hostname is unchanged from the old deployment, so the redirect URI already
# registered on your OAuth client keeps working — only DNS moves to this box.
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REDIRECT_URI=https://mnemos-agent.aryangorde.com/auth/google/callback

# --- Public URLs ---
# Browser-facing agent URL (used to build the "connect google" OAuth link).
AGENT_PUBLIC_URL=https://mnemos-agent.aryangorde.com
# Where the agent redirects the browser after OAuth (the web origin).
MNEMOS_WEB_URL=https://mnemos.aryangorde.com
