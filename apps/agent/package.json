{
  "name": "@mnemos/agent",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env.local src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file=../../.env.local dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "2.8.5",
    "express": "5.0.1",
    "google-auth-library": "9.15.0",
    "mongodb": "6.12.0",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/cors": "2.8.17",
    "@types/express": "5.0.0",
    "@types/node": "22.10.5",
    "tsx": "4.19.2",
    "typescript": "5.7.3"
  }
}
