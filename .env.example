# Mnemos environment variables — copy to .env.local at repo root and fill in.
# Never commit real secrets. Both apps load this via dotenv from the workspace root.

# --- MongoDB Atlas ---
MONGODB_URI=mongodb+srv://USER:PASS@CLUSTER.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=mnemos
MONGODB_VECTOR_INDEX=mnemos_vector_index
MONGODB_TEXT_INDEX=mnemos_text_index

# --- MongoDB MCP server ---
# The MongoDB MCP server is the primary retrieval path and is ON by default
# (spawned via `npx mongodb-mcp-server`). Set to 0 to use the direct driver only.
MNEMOS_USE_MCP=1
# MNEMOS_MCP_DEBUG=1   # uncomment to log MCP stderr / errors

# --- Google Cloud / Vertex AI ---
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=
# Gemini 3.x preview is served from the GLOBAL endpoint; embeddings stay regional.
VERTEX_GEMINI_MODEL=gemini-3.1-pro-preview
VERTEX_GEMINI_LOCATION=global
VERTEX_EMBEDDING_MODEL=text-embedding-004

# --- Gemini API (free-tier alternative to Vertex) ---
# An AI Studio key (https://aistudio.google.com/apikey) routes ALL Gemini +
# embedding calls through the Gemini API instead of paid Vertex — no GCP
# billing needed. Takes precedence over Vertex when set. The free tier covers
# flash-class models only, so pair it with e.g.:
#   VERTEX_GEMINI_MODEL=gemini-flash-latest
GEMINI_API_KEY=

# --- Agent backend ---
AGENT_PORT=8787
AGENT_PUBLIC_URL=http://localhost:8787
# Where the agent redirects after Google OAuth (your web app origin).
MNEMOS_WEB_URL=http://localhost:3000

# --- Google OAuth (Gmail send + Google Calendar) ---
# Create an OAuth 2.0 Client (type: Web) in Google Cloud, enable the Gmail API
# and the Calendar API, and add the redirect URI below to the client.
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REDIRECT_URI=http://localhost:8787/auth/google/callback

# --- Web (FastHTML frontend) ---
# The frontend calls the agent server-side at this URL.
AGENT_URL=http://localhost:8787

# --- Firebase Auth (optional; config-gated, agent-side) ---
# Set this to a Firebase project id to enforce ID-token verification on
# mutating/agent requests. Leave unset to run the agent open.
FIREBASE_PROJECT_ID=
