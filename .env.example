# Mnemos environment variables — copy to .env.local at repo root and fill in.
# Never commit real secrets. Both apps load this via dotenv from the workspace root.

# --- MongoDB Atlas ---
MONGODB_URI=mongodb+srv://USER:PASS@CLUSTER.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=mnemos
MONGODB_VECTOR_INDEX=mnemos_vector_index

# --- Google Cloud / Vertex AI ---
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=
VERTEX_GEMINI_MODEL=gemini-3-pro
VERTEX_EMBEDDING_MODEL=text-embedding-004

# --- Agent backend ---
AGENT_PORT=8787
AGENT_PUBLIC_URL=http://localhost:8787

# --- Web ---
NEXT_PUBLIC_AGENT_URL=http://localhost:8787

# --- Firebase Auth (added in Layer 4) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
